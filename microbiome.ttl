@prefix ex: <https://sherry-misato.github.io/gut-microbiome-lod/microbiome.ttl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix schema: <https://schema.org/> .

# ==================================================
# LOD全体の情報
# ==================================================

ex:FoodGutMicrobiomeLOD
    a schema:Dataset ;
    dct:title "食品成分・腸内細菌・健康作用に関するLOD"@ja ;
    dct:description
        "食品、食品成分、食品に含まれる微生物、腸内細菌および健康作用の関係を表現したLODである。"@ja ;
    dct:creator "林美聡"@ja ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:references
        ex:Reference1 ,
        ex:Reference2 ,
        ex:Reference3 .

# ==================================================
# クラスの定義
# ==================================================

ex:Food
    a rdfs:Class ;
    rdfs:label "食品"@ja ;
    rdfs:comment
        "人が食べる食品を表すクラス。"@ja .

ex:FoodComponent
    a rdfs:Class ;
    rdfs:label "食品成分"@ja ;
    rdfs:comment
        "食品に含まれる食物繊維、オリゴ糖、ポリフェノールなどの成分を表すクラス。"@ja .

ex:Microorganism
    a rdfs:Class ;
    rdfs:label "微生物"@ja ;
    rdfs:comment
        "細菌などの微小な生物を表すクラス。"@ja .

ex:GutBacterium
    a rdfs:Class ;
    rdfs:subClassOf ex:Microorganism ;
    rdfs:label "腸内細菌"@ja ;
    rdfs:comment
        "消化管内に存在する細菌を表すクラス。"@ja .

ex:FoodMicroorganism
    a rdfs:Class ;
    rdfs:subClassOf ex:Microorganism ;
    rdfs:label "食品に含まれる微生物"@ja ;
    rdfs:comment
        "発酵食品などに含まれる微生物を表すクラス。"@ja .

ex:HealthEffect
    a rdfs:Class ;
    rdfs:label "健康作用"@ja ;
    rdfs:comment
        "食品成分または腸内細菌との関連が報告されている健康作用を表すクラス。"@ja .

ex:Reference
    a rdfs:Class ;
    rdfs:label "参考文献"@ja ;
    rdfs:comment
        "LODの情報の根拠として使用した文献を表すクラス。"@ja .

# ==================================================
# プロパティの定義
# ==================================================

ex:containsComponent
    a rdf:Property ;
    rdfs:label "含む食品成分"@ja ;
    rdfs:comment
        "食品に含まれる成分を表す。"@ja ;
    rdfs:domain ex:Food ;
    rdfs:range ex:FoodComponent .

ex:containsMicroorganism
    a rdf:Property ;
    rdfs:label "含む微生物"@ja ;
    rdfs:comment
        "食品に含まれる微生物を表す。"@ja ;
    rdfs:domain ex:Food ;
    rdfs:range ex:FoodMicroorganism .

ex:associatedWithGrowthOf
    a rdf:Property ;
    rdfs:label "増殖との関連が報告されている腸内細菌"@ja ;
    rdfs:comment
        "食品成分の摂取と増殖または存在量との関連が報告されている腸内細菌を表す。"@ja ;
    rdfs:domain ex:FoodComponent ;
    rdfs:range ex:GutBacterium .

ex:associatedWith
    a rdf:Property ;
    rdfs:label "関連する健康作用"@ja ;
    rdfs:comment
        "食品成分または腸内細菌との関連が報告されている健康作用を表す。"@ja ;
    rdfs:range ex:HealthEffect .

ex:hasReference
    a rdf:Property ;
    rdfs:label "参考文献"@ja ;
    rdfs:comment
        "情報の根拠として使用した文献を表す。"@ja ;
    rdfs:range ex:Reference .

# ==================================================
# 食品のインスタンス
# ==================================================

ex:Yogurt
    a ex:Food ;
    rdfs:label "ヨーグルト"@ja ;
    rdfs:label "Yogurt"@en ;
    ex:containsMicroorganism ex:BifidobacteriumFoodCulture ;
    ex:hasReference ex:Reference1 .

ex:Banana
    a ex:Food ;
    rdfs:label "バナナ"@ja ;
    rdfs:label "Banana"@en ;
    ex:containsComponent ex:Fructooligosaccharide ;
    ex:hasReference ex:Reference2 .

ex:Onion
    a ex:Food ;
    rdfs:label "玉ねぎ"@ja ;
    rdfs:label "Onion"@en ;
    ex:containsComponent ex:Inulin ;
    ex:hasReference ex:Reference2 .

ex:Garlic
    a ex:Food ;
    rdfs:label "にんにく"@ja ;
    rdfs:label "Garlic"@en ;
    ex:containsComponent ex:Inulin ;
    ex:hasReference ex:Reference2 .

ex:Blueberry
    a ex:Food ;
    rdfs:label "ブルーベリー"@ja ;
    rdfs:label "Blueberry"@en ;
    ex:containsComponent ex:Polyphenol ;
    ex:hasReference ex:Reference3 .

# ==================================================
# 食品成分のインスタンス
# ==================================================

ex:Fructooligosaccharide
    a ex:FoodComponent ;
    rdfs:label "フラクトオリゴ糖"@ja ;
    rdfs:label "Fructooligosaccharide"@en ;
    ex:associatedWithGrowthOf ex:BifidobacteriumGenus ;
    ex:associatedWith ex:IntestinalEnvironment ;
    ex:hasReference ex:Reference2 .

ex:Inulin
    a ex:FoodComponent ;
    rdfs:label "イヌリン"@ja ;
    rdfs:label "Inulin"@en ;
    ex:associatedWithGrowthOf ex:BifidobacteriumGenus ;
    ex:associatedWith ex:IntestinalEnvironment ;
    ex:hasReference ex:Reference2 .

ex:Polyphenol
    a ex:FoodComponent ;
    rdfs:label "ポリフェノール"@ja ;
    rdfs:label "Polyphenol"@en ;
    ex:associatedWithGrowthOf ex:AkkermansiaMuciniphila ;
    ex:associatedWith ex:IntestinalBarrierFunction ;
    ex:hasReference ex:Reference3 .

# ==================================================
# 食品に含まれる微生物
# ==================================================

ex:BifidobacteriumFoodCulture
    a ex:FoodMicroorganism ;
    rdfs:label "ヨーグルトに使用されるビフィズス菌"@ja ;
    rdfs:label "Bifidobacterium used in yogurt culture"@en ;
    ex:associatedWith ex:IntestinalEnvironment ;
    ex:hasReference ex:Reference1 .

# ==================================================
# 腸内細菌のインスタンス
# ==================================================

ex:BifidobacteriumGenus
    a ex:GutBacterium ;
    rdfs:label "Bifidobacterium属"@ja ;
    rdfs:label "Bifidobacterium"@en ;
    ex:associatedWith ex:IntestinalEnvironment ;
    ex:hasReference ex:Reference2 .

ex:AkkermansiaMuciniphila
    a ex:GutBacterium ;
    rdfs:label "アッカーマンシア・ムシニフィラ"@ja ;
    rdfs:label "Akkermansia muciniphila"@en ;
    ex:associatedWith ex:IntestinalBarrierFunction ;
    ex:hasReference ex:Reference3 .

# ==================================================
# 健康作用のインスタンス
# ==================================================

ex:IntestinalEnvironment
    a ex:HealthEffect ;
    rdfs:label "腸内環境との関連"@ja ;
    rdfs:label "Association with intestinal environment"@en .

ex:IntestinalBarrierFunction
    a ex:HealthEffect ;
    rdfs:label "腸管バリア機能との関連"@ja ;
    rdfs:label "Association with intestinal barrier function"@en .

# ==================================================
# 参考文献のインスタンス
# ==================================================

ex:Reference1
    a ex:Reference ;
    dct:title
        "ヨーグルトおよび発酵乳に含まれる微生物に関する参考文献"@ja ;
    schema:url <https://pubmed.ncbi.nlm.nih.gov/> .

ex:Reference2
    a ex:Reference ;
    dct:title
        "イヌリン、フラクトオリゴ糖およびBifidobacteriumに関する参考文献"@ja ;
    schema:url <https://pubmed.ncbi.nlm.nih.gov/> .

ex:Reference3
    a ex:Reference ;
    dct:title
        "ポリフェノールおよびAkkermansia muciniphilaに関する参考文献"@ja ;
    schema:url <https://pubmed.ncbi.nlm.nih.gov/> .
